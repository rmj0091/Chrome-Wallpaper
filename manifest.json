{
    "manifest_version": 3,
    "name": "Custom tab",
    "version": "1.1.1",
    "description": "Customize new tab page.",
    "permissions": ["history"],
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": ["https://api.github.com/*"]
}
